# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (recursive — covers backend/node_modules too)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
coverage/

# next.js
/.next/
/out/
.swc/

# nest.js build output
dist/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real secrets, but KEEP the example templates
.env
.env.local
.env.*.local
backend/.env
!.env.example
!backend/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
